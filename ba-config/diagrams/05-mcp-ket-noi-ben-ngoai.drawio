        <mxCell id="ba-msg" value="&quot;Tìm tất cả issues P0&#xa;trong sprint hiện tại&quot;" style="shape=callout;whiteSpace=wrap;html=1;perimeter=calloutPerimeter;size=15;position=0.5;position2=1;base=15;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=8;" vertex="1" parent="1">
