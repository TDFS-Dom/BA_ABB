        <!-- MCP Layer -->
        <mxCell id="mcp-container" value="MCP Layer (.kiro/settings/mcp.json)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;verticalAlign=top;spacingTop=8;arcSize=6;opacity=40;" vertex="1" parent="1">
