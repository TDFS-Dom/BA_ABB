<mxfile host="app.diagrams.net" modified="2026-04-23" type="device">
  <diagram name="MCP - Kết nối bên ngoài" id="mcp-flow">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="750" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

