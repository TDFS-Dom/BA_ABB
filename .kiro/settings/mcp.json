{
  "mcpServers": {
    "jira": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-atlassian"],
      "env": {
        "ATLASSIAN_API_TOKEN": "${JIRA_API_TOKEN}",
        "ATLASSIAN_EMAIL": "${JIRA_EMAIL}",
        "ATLASSIAN_DOMAIN": "${JIRA_DOMAIN}"
      },
      "autoApprove": [
        "search_issues",
        "get_issue",
        "list_sprints"
      ],
      "disabled": true
    },
    "confluence": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-atlassian"],
      "env": {
        "ATLASSIAN_API_TOKEN": "${CONFLUENCE_API_TOKEN}",
        "ATLASSIAN_EMAIL": "${CONFLUENCE_EMAIL}",
        "ATLASSIAN_DOMAIN": "${CONFLUENCE_DOMAIN}"
      },
      "autoApprove": [
        "search_pages",
        "get_page"
      ],
      "disabled": true
    }
  },
  "env":{
    "ATLASSIAN_API_TOKEN":"",
    "ATLASSIAN_DOMAIN":"jira.gencdp.com",
    "ATLASSIAN_EMAIL":"devtoannh@gmail.com"
  }
}